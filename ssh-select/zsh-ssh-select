#!/usr/bin/env zsh
#
# ssh-select - Simple SSH host picker (using fzf)
# Usage: ssh-select [host]

SSH_CONFIG="$HOME/.ssh/config"

if [[ ! -f "$SSH_CONFIG" ]]; then
  echo "❌ ~/.ssh/config not found"
  exit 1
fi

# 提取所有 Host
hosts=($(sed -n 's/^Host[[:space:]]*\([^\#*]*\)[[:space:]]*$/\1/p' "$SSH_CONFIG" | sort -u))

if [[ $# -eq 1 ]]; then
  # 直接连接指定主机
  target="$1"
  if [[ ${hosts[(i)$target]} -le ${#hosts} ]]; then
    exec ssh "$target"
  else
    echo "❌ Host '$target' not found"
    exit 1
  fi
fi

# 交互式选择（使用 fzf）
if [[ -z "$hosts" ]]; then
  echo "❌ No hosts found in ~/.ssh/config"
  exit 1
fi

selected=$(printf '%s\n' "${hosts[@]}" | fzf --prompt="🔐 SSH Select > " --height=~50% --border --inline-info)

if [[ -n "$selected" ]]; then
  exec ssh "$selected"
fi