#!/usr/bin/env zsh
#
# ssh-select - Simple SSH host picker
# Usage: ssh-select [host]

SSH_CONFIG="$HOME/.ssh/config"

if [[ ! -f "$SSH_CONFIG" ]]; then
  echo "❌ ~/.ssh/config not found"
  exit 1
fi

# 提取所有 Host
hosts=($(sed -n 's/^Host[[:space:]]*\([^\#*]*\)[[:space:]]*$/\1/p' "$SSH_CONFIG" | sort -u))

if [[ $# -eq 1 ]]; then
  # 直接连接指定主机
  target="$1"
  if [[ ${hosts[(i)$target]} -le ${#hosts} ]]; then
    exec ssh "$target"
  else
    echo "❌ Host '$target' not found"
    exit 1
  fi
fi

# 交互式选择
echo "🔐 SSH Select (${#hosts} hosts found)"
echo "----------------------------------------"
select host in "${hosts[@]}"; do
  if [[ -n "$host" ]]; then
    exec ssh "$host"
  fi
done